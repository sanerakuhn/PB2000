<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PipBoy2000.Models"
             x:Class="PipBoy2000.Views.CharacterSheetPage"
             Title=""
             Padding="20">

    <Frame BackgroundColor="#0F141A"
           BorderColor="{StaticResource FalloutBorder}"
           CornerRadius="12"
           Padding="30"
           HasShadow="True"
           Shadow="{StaticResource PipBoyGlowShadow}"
           VerticalOptions="FillAndExpand"
           HorizontalOptions="FillAndExpand">

        <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*">

            <Frame Grid.Row="0" BorderColor="{StaticResource FalloutBorder}" Padding="10" Margin="0,0,0,20">
                <Grid Grid.Row="0" RowDefinitions="*,*,*" ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*,Auto" Margin="10,10,10,20" Padding="10" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
                    <Label Grid.Row="0" Grid.Column="0" WidthRequest="100" Text="Name:" Padding="10" VerticalOptions="Center" HorizontalTextAlignment="End" HorizontalOptions="End"/>
                    <Entry Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" WidthRequest="300" Text="{Binding CharacterName}"
                               HorizontalOptions="Start"
                               Placeholder="Enter name" />

                    <Label Grid.Row="1" Grid.Column="0" WidthRequest="100" Text="Level:" Margin="0,8,0,0" Padding="10" VerticalOptions="Center" HorizontalTextAlignment="End" HorizontalOptions="End"/>
                    <Entry Grid.Row="1" Grid.Column="1" WidthRequest="100" Text="{Binding Level}" Margin="0,8,0,0" Keyboard="Numeric" HorizontalOptions="Start"/>
                    <Label Grid.Row="1" Grid.Column="2" WidthRequest="100" Text="Origin:" Margin="0,8,0,0" Padding="10" VerticalOptions="Center" HorizontalTextAlignment="End" HorizontalOptions="End"/>
                    <Entry Grid.Row="1" Grid.Column="3" WidthRequest="100" Text="{Binding Origin}" Margin="0,8,0,0" HorizontalOptions="Start"/>
                    <Entry Grid.Row="1" Grid.Column="5" Text="{Binding SubOrigin}" Margin="0,8,0,0" HorizontalOptions="Start"/>

                    <Label Grid.Row="2" Grid.Column="0" WidthRequest="100" Text="XP Earned:" Margin="0,8,0,0" Padding="10" VerticalOptions="Center" HorizontalTextAlignment="End" HorizontalOptions="End"/>
                    <Entry Grid.Row="2" Grid.Column="1" WidthRequest="100" Text="{Binding XpEarned}" Margin="0,8,0,0" Keyboard="Numeric"  HorizontalOptions="Start"/>
                    <Label Grid.Row="2" Grid.Column="2" WidthRequest="100" Text="Next:" Margin="0,8,0,0" Padding="10" VerticalOptions="Center" HorizontalTextAlignment="End" HorizontalOptions="End"/>
                    <Entry Grid.Row="2" Grid.Column="3" WidthRequest="100" Text="{Binding XpToNextLevel}" Margin="0,8,0,0" Keyboard="Numeric"  HorizontalOptions="Start"/>

                    <Label Grid.Row="0" Grid.Column="6" Text="Luck Points:" Padding="10" VerticalOptions="Center" HorizontalOptions="End" />
                    <Entry Grid.Row="0" Grid.Column="7" Text="{Binding LuckPoints}" Keyboard="Numeric" WidthRequest="80" HorizontalOptions="End" />
                </Grid>
            </Frame>

                <HorizontalStackLayout Grid.Row="1" Grid.RowSpan="1"
                                   Spacing="10"
                                   VerticalOptions="StartAndExpand"
                                   HorizontalOptions="Center"
                                   Margin="0,0,0,20">
                    <Button Text="Stats"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="SPECIAL">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Button Text="Skills"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="Skills">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Button Text="Combat"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="Combat">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Button Text="Weapons"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="Weapons">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>
                    
                    <Button Text="Inventory"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="Inventory">
                    <Button.GestureRecognizers>
                        <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Button Text="Perks"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        HeightRequest="45"
                        WidthRequest="160"
                        Clicked="OnTabTapped"
                        CommandParameter="Perks">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>
            </HorizontalStackLayout>
            
            <ScrollView Grid.Row="2">
                <ContentView x:Name="TabContent"
                             VerticalOptions="FillAndExpand"
                             HorizontalOptions="FillAndExpand" />
            </ScrollView>

            <BoxView Grid.RowSpan="3"
                     Style="{StaticResource ScanlineOverlay}"
                     InputTransparent="True" />

        </Grid>
    </Frame>
</ContentPage>