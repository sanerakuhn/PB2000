<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PipBoy2000.Views.OriginSelectionPage"
             Title=""
             Padding="20">

    <Frame BackgroundColor="#0F141A"
           BorderColor="{StaticResource FalloutBorder}"
           CornerRadius="12"
           Padding="30"
           HasShadow="True"
           Shadow="{StaticResource PipBoyGlowShadow}"
           VerticalOptions="FillAndExpand"
           HorizontalOptions="FillAndExpand">

        <Grid RowDefinitions="*" ColumnDefinitions="*">

            <VerticalStackLayout Spacing="40"
                                 VerticalOptions="FillAndExpand"
                                 HorizontalOptions="FillAndExpand">

                <Label Text="SELECT YOUR ORIGIN"
                       FontSize="48"
                       Style="{StaticResource PipBoyHeader}"
                       VerticalOptions="Start"
                       HorizontalOptions="Center"
                       Margin="0,0,0,40" />

                <HorizontalStackLayout Spacing="25"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">

                    <VerticalStackLayout Spacing="25"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">

                        <Button Text="Brotherhood Initiate"
                            Style="{StaticResource PipBoyButton}"
                            FontSize="18"
                            HeightRequest="60"
                            WidthRequest="200"
                            Clicked="OnOriginClicked"
                            CommandParameter="Brotherhood Initiate">
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>

                        <Button Text="Ghoul"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="18"
                        HeightRequest="60"
                        WidthRequest="200"
                        Clicked="OnOriginClicked"
                        CommandParameter="Ghoul">
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                          PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>

                        <Button Text="Super Mutant"
                            Style="{StaticResource PipBoyButton}"
                            FontSize="18"
                        HeightRequest="60"
                        WidthRequest="200"
                            Clicked="OnOriginClicked"
                            CommandParameter="Super Mutant">
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                          PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>

                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="25"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center">
                        <Button Text="Mister Handy"
                            Style="{StaticResource PipBoyButton}"
                            FontSize="18"
                            HeightRequest="60"
                            WidthRequest="200"
                            Clicked="OnOriginClicked"
                            CommandParameter="Mister Handy">
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                          PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>

                        <Button Text="Survivor"
                            Style="{StaticResource PipBoyButton}"
                            FontSize="18"
                            HeightRequest="60"
                            WidthRequest="200"
                            Clicked="OnOriginClicked"
                            CommandParameter="Survivor">
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                          PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>

                        <Button Text="Vault Dweller"
                            Style="{StaticResource PipBoyButton}"
                            FontSize="18"
                            HeightRequest="60"
                            WidthRequest="200"
                            Clicked="OnOriginClicked"
                            CommandParameter="Vault Dweller" >
                            <Button.GestureRecognizers>
                                <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                          PointerExited="OnButtonHoverExited" />
                            </Button.GestureRecognizers>
                        </Button>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView Style="{StaticResource ScanlineOverlay}"
                     InputTransparent="True" />

        </Grid>
    </Frame>
</ContentPage>