<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PipBoy2000.Views.MainPage"
             Title=""
             Padding="20">

    <Frame BackgroundColor="#0F141A"
           BorderColor="{StaticResource FalloutBorder}"
           CornerRadius="12"
           Padding="30"
           HasShadow="True"
           Shadow="{StaticResource PipBoyGlowShadow}"
           VerticalOptions="FillAndExpand"
        HorizontalOptions="FillAndExpand">

        <Grid RowDefinitions="*" ColumnDefinitions="*">

            <VerticalStackLayout Spacing="50"
                                 VerticalOptions="FillAndExpand"
                HorizontalOptions="FillAndExpand">

                <Label Text="PIP-BOY 2000"
                       FontSize="48"
                       Style="{StaticResource PipBoyHeader}"
                       VerticalOptions="Start"
                       HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="50"
                                     VerticalOptions="Center"
                    HorizontalOptions="Center">

                    <Button x:Name="btnLoad"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        FontAttributes="Bold"
                        HeightRequest="140"
                        WidthRequest="600"
                        CornerRadius="8"
                        Padding="40,20"
                        Text="LOAD EXISTING CHARACTER"
                        Clicked="OnLoadClicked">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                  PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                    <Button x:Name="btnCreateNew"
                        Style="{StaticResource PipBoyButton}"
                        FontSize="24"
                        FontAttributes="Bold"
                        HeightRequest="140"
                        WidthRequest="600"
                        CornerRadius="8"
                        Padding="40,20"
                        Text="CREATE NEW CHARACTER"
                        Clicked="OnCreateNewClicked">
                        <Button.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="OnButtonHoverEntered"
                                                      PointerExited="OnButtonHoverExited" />
                        </Button.GestureRecognizers>
                    </Button>

                </VerticalStackLayout>

            </VerticalStackLayout>

            <BoxView Style="{StaticResource ScanlineOverlay}"
                     InputTransparent="True" />

        </Grid>
    </Frame>
</ContentPage>